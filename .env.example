# ============================================
# TALENT_TRACK ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and update with your values
# NEVER commit .env to version control

# ============================================
# JWT & SECURITY
# ============================================

# JWT Secret Key (change in production!)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-change-in-production

# JWT Refresh Secret Key (change in production!)
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# Node Environment
NODE_ENV=development

# ============================================
# SERVER
# ============================================

# Server Port
PORT=3000

# Server Host
HOST=127.0.0.1

# ============================================
# DATABASE
# ============================================

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/studentDB

# MongoDB User (if authentication enabled)
# MONGODB_USER=admin
# MONGODB_PASSWORD=your-password

# ============================================
# REDIS CACHE
# ============================================

# Redis Host
REDIS_HOST=localhost

# Redis Port
REDIS_PORT=6379

# Redis Password (if required)
# REDIS_PASSWORD=your-redis-password

# ============================================
# EXTERNAL APIS
# ============================================

# Google Gemini API Key (for AI features)
# GOOGLE_GEMINI_API_KEY=your-api-key-here

# OpenAI API Key (fallback AI provider)
# OPENAI_API_KEY=your-api-key-here

# ============================================
# AUTHENTICATION
# ============================================

# Access Token Expiry (short-lived)
# Format: "15m", "1h", "7d"
ACCESS_TOKEN_EXPIRY=15m

# Refresh Token Expiry (long-lived)
REFRESH_TOKEN_EXPIRY=7d

# Max Login Attempts Before Lockout
MAX_LOGIN_ATTEMPTS=5

# Account Lockout Duration (minutes)
LOCKOUT_DURATION=15

# ============================================
# CORS
# ============================================

# Allowed Origins (comma-separated)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://example.com

# ============================================
# LOGGING
# ============================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Enable Audit Logging
AUDIT_LOG_ENABLED=true

# Audit Log File Path
AUDIT_LOG_FILE=./logs/audit.log

# ============================================
# FEATURE FLAGS
# ============================================

# Enable Rate Limiting
RATE_LIMITING_ENABLED=true

# Enable RBAC
RBAC_ENABLED=true

# Enable Audit Logging
AUDIT_LOGGING_ENABLED=true

# ============================================
# PRODUCTION ONLY
# ============================================

# Enable HTTPS
# HTTPS_ENABLED=true

# SSL Certificate Path
# SSL_CERT_PATH=/path/to/cert.pem

# SSL Key Path
# SSL_KEY_PATH=/path/to/key.pem

# ============================================
# DEVELOPER OPTIONS
# ============================================

# Skip RBAC for development (NOT recommended for production)
# SKIP_RBAC=false

# Enable request logging
ENABLE_REQUEST_LOG=true

# Enable verbose error messages
VERBOSE_ERRORS=true
